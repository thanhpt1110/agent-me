# agent-me runtime config
#
# Copy this file to `.env` (in the same directory) and fill in real values.
# `.env` is gitignored; never commit secrets.
#
# After filling in, source it before running the bridge:
#   set -a; source ~/agent-me/configs/.env; set +a

# ── Slack ────────────────────────────────────────────────────────────────────
# Bot User OAuth Token — from "OAuth & Permissions" page after installing app.
# Format: xoxb-<digits>-<digits>-<base64>
SLACK_BOT_TOKEN=xoxb-REPLACE-ME

# App-Level Token — generated under "Socket Mode" with `connections:write` scope.
# Format: xapp-<digits>-<id>-<base64>
SLACK_APP_TOKEN=xapp-REPLACE-ME

# Signing Secret — from "Basic Information" → "App Credentials".
# Used to verify Slack request signatures. Hex string.
SLACK_SIGNING_SECRET=REPLACE-ME

# Optional: restrict bridge to one Slack user ID (your own) so a leaked
# bot token can't be exploited by other workspace members. Find via:
#   curl -H "Authorization: Bearer $SLACK_BOT_TOKEN" https://slack.com/api/auth.test
# Leave blank to accept messages from any workspace member (fine for solo workspace).
SLACK_ALLOWED_USER_ID=

# ── Anthropic / Claude Code ─────────────────────────────────────────────────
# Path to the agent-me repo root (where CLAUDE.md lives). The bridge spawns
# `claude -p` with this as cwd so the agent inherits project context.
AGENT_ME_REPO_DIR=/home/agent/agent-me

# Where the bridge stores conversation state (SQLite). XDG-compliant default;
# override if you want it somewhere else (e.g. /data/agent-me).
AGENT_ME_STATE_DIR=

# Model override (optional). Bridge pins claude-opus-4-7 by default. Update
# this line manually when a newer Opus ships; the bridge does not query the
# Anthropic API on its own.
# CLAUDE_MODEL=claude-opus-4-7

# ── Brief MCP-fetch backend ─────────────────────────────────────────────
# Which CLI does daily-brief shell out to for the MCP query step?
#   - claude (default): Claude Code CLI. Reliable JSON output. MCP auth
#     expires ~daily on NVIDIA org-policied installs.
#   - pa: NVIDIA Personal Assistant CLI (`pa login` once on host). May
#     hold MCP auth longer + may fetch faster vs claude --allowedTools.
# The Slack bridge ALWAYS uses Claude Code regardless — this only
# affects the agent-me-brief subprocess.
# MCP_CLI=claude

# Override timeout for the MCP fetch subprocess (seconds, default 240).
# MCP_CLI_TIMEOUT_S=240

# ── Logging ─────────────────────────────────────────────────────────────────
# debug | info | warn | error
LOG_LEVEL=info
